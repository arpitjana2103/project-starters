{
    "name": "project-name",
    "version": "1.0.0",
    "description": "task management full-stack application",
    "homepage": "",
    "license": "ISC",
    "author": "Arpit Jana",
    "repository": {
        "type": "git",
        "url": ""
    },
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "start:dev": "cross-env NODE_ENV=development tsx watch --clear-screen=true src/index.ts",
        "start:dev-prod": "cross-env NODE_ENV=production tsx watch --clear-screen=true src/index.ts",
        "start:prod": "cross-env NODE_ENV=production node dist/index.js",
        "build": "rimraf dist && tsc",
        "typecheck": "tsc --noEmit",
        "typecheck:watch": "tsc --noEmit --watch",
        "fmt": "oxfmt --config .oxfmtrc.json .",
        "fmt:check": "oxfmt --config .oxfmtrc.json . --check",
        "lint": "oxlint --config .oxlintrc.json --type-aware .",
        "lint:fix": "oxlint --config .oxlintrc.json --type-aware . --fix"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "copyfiles": "^2.4.1",
        "cross-env": "^10.1.0",
        "oxfmt": "^0.41.0",
        "oxlint": "^1.56.0",
        "oxlint-tsgolint": "^0.21.0",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
