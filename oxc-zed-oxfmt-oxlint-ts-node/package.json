{
    "name": "full-stack-notes-app-backend",
    "version": "1.0.0",
    "description": "",
    "license": "ISC",
    "author": "Arpit Jana",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "start:dev": "cross-env NODE_ENV=development tsx watch --clear-screen=true src/index.ts",
        "start:dev-prod": "cross-env NODE_ENV=production tsx watch --clear-screen=true src/index.ts",
        "start:prod": "cross-env NODE_ENV=production node dist/index.js",
        "build": "rimraf dist && tsc",
        "typecheck": "tsc --noEmit",
        "typecheck:watch": "tsc --noEmit --watch",
        "fmt": "oxfmt --config .oxfmtrc.json .",
        "fmt:check": "oxfmt --config .oxfmtrc.json . --check",
        "lint": "oxlint --config .oxlintrc.json --type-aware .",
        "lint:fix": "oxlint --config .oxlintrc.json --type-aware . --fix",
        "prisma:generate": "prisma generate",
        "prisma:migrate:dev": "prisma migrate dev",
        "prisma:migrate:deploy": "prisma migrate deploy",
        "prisma:studio": "prisma studio",
        "prisma:reset": "prisma migrate reset",
        "prisma:format": "prisma format"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@types/node": "^26.1.0",
        "cross-env": "^10.1.0",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-session": "^1.19.0",
        "ms": "^2.1.3",
        "oxfmt": "^0.58.0",
        "oxlint": "^1.73.0",
        "pg": "^8.22.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "rimraf": "^6.1.3",
        "tsx": "^4.23.0",
        "typescript": "^6.0.3",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/express-session": "^1.19.0",
        "@types/ms": "^2.1.0",
        "@types/passport": "^1.0.17",
        "@types/pg": "^8.20.0",
        "prisma": "^7.8.0"
    },
    "allowScripts": {
        "esbuild@0.28.1": true,
        "prisma@7.8.0": true,
        "@prisma/engines@7.8.0": true
    }
}
