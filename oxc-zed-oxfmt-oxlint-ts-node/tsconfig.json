{
    "compilerOptions": {
        // Target JavaScript version that TypeScript compiles to.
        // ES2022 works well with modern Node (Node 18+).
        "target": "ES2022",

        // Module system used in emitted JS.
        // NodeNext enables native Node.js ESM behavior and works with "type": "module".
        "module": "NodeNext",

        // How TypeScript resolves imports.
        // NodeNext matches Node's ESM/CJS resolution rules (.js extensions, package exports, etc).
        "moduleResolution": "NodeNext",

        // Root folder of your TypeScript source files.
        // Helps TypeScript preserve folder structure when compiling.
        "rootDir": "./src",

        // Output directory where compiled JavaScript files go.
        // Example: src/index.ts → dist/index.js
        "outDir": "./dist",

        // Enables all strict type-checking options.
        // Includes: strictNullChecks, noImplicitAny, strictFunctionTypes, etc.
        "strict": true,

        // Allows default imports from CommonJS modules.
        // Example: import express from "express"
        "esModuleInterop": true,

        // Skips type checking of declaration files (.d.ts) inside node_modules.
        // Speeds up compilation and avoids third-party typing issues.
        "skipLibCheck": true,

        // Ensures import paths match exact file casing.
        // Prevents issues when moving between Windows (case-insensitive) and Linux.
        "forceConsistentCasingInFileNames": true,

        // Allows importing JSON files directly.
        // Example: import config from "./config.json"
        "resolveJsonModule": true,

        // Generates .d.ts type declaration files alongside compiled JS.
        // Useful if your project is a library.
        "declaration": false,

        // Generates .map files linking compiled JS to original TS.
        // Useful for debugging in IDEs and Node debuggers.
        "sourceMap": false,
    },

    // Specifies which files TypeScript should include in the compilation.
    // Here it compiles everything inside src/
    "include": ["src"],

    // Files or folders TypeScript should ignore.
    // node_modules: dependencies
    // dist: compiled output
    "exclude": ["node_modules", "dist"],
}
