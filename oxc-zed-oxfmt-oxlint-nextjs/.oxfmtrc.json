{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "ignorePatterns": ["/components/ui/**"],
    "tabWidth": 4,
    "sortTailwindcss": {
        "stylesheet": "./app/globals.css"
    },
    "sortImports": {
        "groups": [
            "side_effect",
            "builtin",
            "type",
            "external",
            ["internal", "subpath"],
            ["parent", "sibling", "index"],
            "style",
            "unknown"
        ],
        "newlinesBetween": true,
        "ignoreCase": true
    }
}
